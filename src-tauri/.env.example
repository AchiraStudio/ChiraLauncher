# ChiraLauncher — Environment Variables
# Copy this file to .env and fill in your values.
# Tauri reads .env automatically from the src-tauri directory during `npm run dev`.

# ── IGDB / Twitch API Credentials ──────────────────────────────────────────
# Create an app at https://dev.twitch.tv/console and enable IGDB access.
# NOTE: IGDB_CLIENT_ID and IGDB_CLIENT_SECRET must BOTH be set to enable live search.
# Your Client ID (from Twitch Dev Console):
IGDB_CLIENT_ID=khbdrdb57cp07tkqeyc8ctlwts308o

# Your Client Secret (from Twitch Dev Console — keep this private!):
IGDB_CLIENT_SECRET=
